# Copy to .env and fill in. NEVER commit this file.
# The bot reads DISCORD_BOT_TOKEN from here.

# Primary interface (required to run the Discord bot)
DISCORD_BOT_TOKEN=

# Outbound agent -> Discord channel relay (optional)
DISCORD_WEBHOOK_URL=

# Live capabilities (optional)
WEB_SEARCH_API_KEY=
LLM_API_KEY=

# Optional / deprecated transport
TELEGRAM_BOT_TOKEN=

# KAGE runtime knobs (optional)
KAGE_PRIMARY_INTERFACE=discord
KAGE_USE_TELEGRAM=false
KAGE_LOG_LEVEL=INFO
